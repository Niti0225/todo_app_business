    .title{
      margin:0; font-weight:900; letter-spacing:.3px;
      font-size:clamp(26px,3.4vw,38px); line-height:1.1;
      background:linear-gradient(90deg,var(--grad-start),var(--grad-end));
      -webkit-background-clip:text; background-clip:text; color:transparent;
      text-shadow:0 4px 24px rgba(154,77,255,.15);
    }
    .subtitle{margin:10px 0 0; color:var(--muted); font-weight:600; letter-spacing:.2px}

    /* Language toggle */
    .langbar{
      margin-top:16px; display:flex; gap:8px; align-items:center; justify-content:flex-end;
    }
    .chip{
      border:1px solid var(--line);
      background:rgba(255,255,255,.04);
      color:var(--text);
      padding:8px 12px; border-radius:999px; font-weight:800; letter-spacing:.2px;
      cursor:pointer; transition:transform .2s ease, box-shadow .2s ease, border-color .2s ease, background .2s ease;
    }
    .chip[aria-pressed="true"]{
      background:linear-gradient(90deg,var(--grad-start),var(--grad-end));
      border-color:rgba(255,255,255,.2); box-shadow:var(--shadow-soft); transform:translateY(-1px);
    }

    main{padding:28px 0 48px}
    .card{
      background:linear-gradient(180deg, rgba(255,255,255,.04), rgba(255,255,255,.02));
      border:1px solid var(--line); border-radius:var(--radius);
      box-shadow:var(--shadow-lg); padding:22px; backdrop-filter:blur(10px);
    }
    h2{
      margin:0 0 14px; font-size:18px; font-weight:900; letter-spacing:.2px;
      background:linear-gradient(90deg,var(--grad-start),var(--grad-end));
      -webkit-background-clip:text; background-clip:text; color:transparent;
    }
    .grid{display:grid; gap:22px}
    .row{display:grid; grid-template-columns:210px 1fr; gap:12px; padding:10px 0; border-bottom:1px dashed var(--line)}
    .row:last-child{border-bottom:none}
    .k{color:var(--muted); font-weight:700}
    .v{font-weight:800}
    .muted{color:var(--muted); font-weight:600}
    .block{margin:14px 0}
    .stamp{margin-top:8px; color:var(--muted); font-size:13px; font-weight:600}

    .actions{display:flex; gap:10px; margin-top:16px; flex-wrap:wrap}
    .btn{
      display:inline-flex; align-items:center; gap:10px;
      padding:10px 14px; border-radius:12px; font-weight:900; letter-spacing:.2px;
      border:1px solid var(--line); background:rgba(255,255,255,.03);
      transition:transform .25s, box-shadow .25s, border-color .25s, background .25s;
    }
    .btn:hover{transform:translateY(-2px); border-color:rgba(255,255,255,.12); box-shadow:var(--shadow-soft); background:linear-gradient(180deg, rgba(255,255,255,.04), rgba(255,255,255,.02));}

