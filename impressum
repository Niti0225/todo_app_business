  <script>
    (function(){
      const qs = new URLSearchParams(location.search);
      const saved = localStorage.getItem('hg_lang');
      const fromQS = (qs.get('lang') || '').toLowerCase();
      const browserIsDe = (navigator.language || 'en').toLowerCase().startsWith('de');
      let lang = (fromQS === 'de' || fromQS === 'en') ? fromQS
                : (saved === 'de' || saved === 'en') ? saved
                : (browserIsDe ? 'de' : 'en');

      const btnDe = document.getElementById('btn-de');
      const btnEn = document.getElementById('btn-en');
      const secDe = document.getElementById('section-de');
      const secEn = document.getElementById('section-en');

      function apply(l){
        lang = l;
        localStorage.setItem('hg_lang', l);
        document.documentElement.lang = l === 'de' ? 'de' : 'en';
        btnDe.setAttribute('aria-pressed', l === 'de' ? 'true' : 'false');
        btnEn.setAttribute('aria-pressed', l === 'en' ? 'true' : 'false');
        if(l === 'de'){ secDe.classList.remove('hidden'); secEn.classList.add('hidden'); }
        else { secEn.classList.remove('hidden'); secDe.classList.add('hidden'); }
        const url = new URL(location.href);
        url.searchParams.set('lang', l);
        history.replaceState({}, '', url.toString());
      }

      btnDe.addEventListener('click', () => apply('de'));
      btnEn.addEventListener('click', () => apply('en'));
      apply(lang);
    })();
  </script>
